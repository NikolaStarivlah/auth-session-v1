<!-- Login page title -->
<h2>Login</h2>

<!-- Form to submit login credentials to the server via POST request to /login route -->
<form method="POST" action="/login">
    <!-- Input field for username, required for form submission -->
    <input name="username" placeholder="Username" required />
    <!-- Input field for password, type="password" hides the input for security -->
    <input name="password" type="password" placeholder="Password" required />
    <!-- Submit button to send the form data -->
    <button type="submit">Login</button>
</form>